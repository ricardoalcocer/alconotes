{
  "name": "alconotes",
  "productName": "Buffer",
  "version": "0.1.0",
  "description": "A perpetual Markdown notebook — a fast, native-feeling editor in the spirit of CotEditor",
  "main": "main.js",
  "author": "alco",
  "license": "MIT",
  "scripts": {
    "build": "node build.js",
    "watch": "node build.js --watch",
    "start": "npm run build && electron .",
    "dev": "npm run build && electron .",
    "dist": "npm run build && electron-builder && codesign --force --deep --sign - release/mac-arm64/Buffer.app"
  },
  "build": {
    "appId": "com.alco.alconotes",
    "productName": "Buffer",
    "directories": {
      "output": "release"
    },
    "fileAssociations": [
      {
        "ext": [
          "md",
          "markdown",
          "mdown",
          "mkd",
          "mdtext"
        ],
        "name": "Markdown Document",
        "description": "Markdown Document",
        "role": "Editor",
        "rank": "Default"
      },
      {
        "ext": [
          "txt",
          "text"
        ],
        "name": "Plain Text Document",
        "description": "Plain Text Document",
        "role": "Editor",
        "rank": "Alternate"
      }
    ],
    "files": [
      "main.js",
      "context-menu.js",
      "preload.js",
      "index.html",
      "styles.css",
      "dist/renderer.js",
      "assets/**/*",
      "!node_modules/**/*"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        {
          "target": "dmg",
          "arch": "arm64"
        },
        {
          "target": "zip",
          "arch": "arm64"
        }
      ],
      "identity": null
    }
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^25.1.8",
    "esbuild": "^0.23.0"
  },
  "dependencies": {
    "@codemirror/commands": "^6.6.0",
    "@codemirror/lang-markdown": "^6.2.5",
    "@codemirror/language": "^6.10.2",
    "@codemirror/language-data": "^6.5.1",
    "@codemirror/search": "^6.5.6",
    "@codemirror/state": "^6.4.1",
    "@codemirror/view": "^6.28.0",
    "@lezer/highlight": "^1.2.0",
    "codemirror": "^6.0.1",
    "markdown-it": "^14.1.0",
    "markdown-it-mark": "^4.0.0"
  }
}
